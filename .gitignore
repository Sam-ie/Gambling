# Build output directories
build/                  # 整个 build 目录（含 MinGW / Android 所有构建产物）
Desktop_*/              # 防止 QtCreator 在根目录创建 Desktop_xxx 临时目录
Qt_*_for_Android*/      # Android 构建中间目录

# Local dev helpers & env files
*.bat                   # bat 脚本（如 fix_gradle_mirror.bat）
*.user                  # QtCreator 用户配置
*.keystore              # Android 签名密钥（如 android_release.keystore）